# LabeloxAV environment. Copy to .env and adjust. Consumed by docker-compose and the app.
# No secrets that matter for local dev; rotate before any non-local use.

# Postgres (system of record + PostGIS)
POSTGRES_USER=labelox
POSTGRES_PASSWORD=labelox
POSTGRES_DB=labeloxav
POSTGRES_PORT=5432

# MinIO (S3-compatible object store)
MINIO_ROOT_USER=labelox
MINIO_ROOT_PASSWORD=labelox123
MINIO_BUCKET=labeloxav
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# Redis (job state, triage cache, locks)
REDIS_PORT=6379

# Redpanda (Kafka-API event bus)
REDPANDA_PORT=19092
REDPANDA_ADMIN_PORT=9644

# App-side overrides (LBX_ prefix, double underscore for nesting).
# Defaults in configs/default.yaml already target localhost-exposed compose ports.
# Example override:
# LBX_GPU__MODE=sequential
# LBX_LOG_LEVEL=INFO
